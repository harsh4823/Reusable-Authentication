    {
      "name": "Realm OIDC - Discovery & JWKS",
      "item": [
        {
          "name": "OIDC Discovery Document",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Spring sets the XSRF-TOKEN cookie on this response.",
                  "// The collection pre-request script picks it up on subsequent requests.",
                  "const xsrfCookie = pm.cookies.get('XSRF-TOKEN');",
                  "if (xsrfCookie) {",
                  "    pm.collectionVariables.set('xsrfToken', decodeURIComponent(xsrfCookie));",
                  "    console.log('XSRF-TOKEN captured:', decodeURIComponent(xsrfCookie));",
                  "} else {",
                  "    console.warn('XSRF-TOKEN cookie not found. Make sure the server is running.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/:realm/.well-known/openid-configuration",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ":realm",
                ".well-known",
                "openid-configuration"
              ],
              "variable": [
                {
                  "key": "realm",
                  "value": "{{realm}}"
                }
              ]
            }
          },
          "response": []
