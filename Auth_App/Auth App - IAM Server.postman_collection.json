    {
      "name": "Onboarding",
      "item": [
        {
          "name": "Onboard New Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken)  pm.collectionVariables.set('accessToken',  res.accessToken);",
                  "if (res.refreshToken) pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "if (res.realmName)    pm.collectionVariables.set('realm',        res.realmName);",
                  "console.log('Tokens and realm saved to collection variables.');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dev@myapp.com\",\n  \"password\": \"SecurePass123!\",\n  \"name\": \"Dev User\",\n  \"appName\": \"My Awesome App\",\n  \"realmName\": \"my-app-realm\",\n  \"redirectUri\": \"http://localhost:3000/callback\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/onboard",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "onboard"
              ]
            }
          },
          "response": []
        }
      ],
      "description": "Self-service onboarding. /onboard is on the CSRF ignore list — no X-XSRF-TOKEN needed."
    },
